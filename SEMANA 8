using System;
using System.Collections.Generic;

// Clase que representa una página web
class Pagina
{
    public string Url { get; set; }

    public Pagina(string url)
    {
        Url = url;
    }
}

// Clase Navegador
class Navegador
{
    private Stack<Pagina> historial;
    private Pagina paginaActual;

    public Navegador()
    {
        historial = new Stack<Pagina>();
        paginaActual = null;
    }

    // Método para navegar a una nueva página
    public void IrAPagina(string url)
    {
        if (paginaActual != null)
        {
            historial.Push(paginaActual);
        }

        paginaActual = new Pagina(url);
        Console.WriteLine("Página actual: " + paginaActual.Url);
    }

    // Método para retroceder
    public void Retroceder()
    {
        if (historial.Count > 0)
        {
            paginaActual = historial.Pop();
            Console.WriteLine("Retrocediendo a: " + paginaActual.Url);
        }
        else
        {
            Console.WriteLine("No hay páginas anteriores.");
        }
    }}

// Clase principal
class Program
{
    static void Main(string[] args)
    {
        Navegador navegador = new Navegador();

        navegador.IrAPagina("www.google.com");
        navegador.IrAPagina("www.youtube.com");
        navegador.IrAPagina("www.github.com");

        navegador.Retroceder();
        navegador.Retroceder();
        navegador.Retroceder();

        Console.ReadLine();
    }}
